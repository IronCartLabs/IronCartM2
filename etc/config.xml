 /
 / Default scope values for the module's admin configuration tree.
 / Every section here must default to a posture that preserves the
 / "no outbound network without explicit opt-in" invariant from the
 / v0/v1 tracking epic.
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <ironcart_scan>
            <!--
                IC-060 / IC-061 — CVE cross-reference via the ironcart.dev
                proxy. Default is `0` (disabled). When `0`, ComposerCveCheck
                emits a single info-level finding that points the operator
                at Stores → Configuration → Ironcart → Scan to opt in.
            -->
            <cve>
                <enabled>0</enabled>
            </cve>
            <!--
                v3 — opt-in hosted scan reporting (#57).
                `enabled` is the hard invariant: 0 by default so no operator
                accidentally uploads scan data by composer-installing a newer
                module version. The unit test
                `UploadConfigDefaultsTest::testEnabledDefaultIsFalse` asserts
                this stays true.
            -->
            <upload>
                <enabled>0</enabled>
                <endpoint>https://ironcart.dev/api/scan/ingest</endpoint>
                <allowed_host>ironcart.dev</allowed_host>
            </upload>
            <!--
                v4 — continuous-monitoring cron (#64). Default OFF so a
                fresh `composer require` of this module never silently
                starts outbound traffic. When `enabled = 1`, Magento's
                cron framework runs `ironcart_scan_upload_cron` (declared
                in `etc/crontab.xml`) on the schedule below; that handler
                drives the same code path as
                `bin/magento ironcart:scan` with the `upload` flag.

                The schedule string here is the system default consulted
                by the {@see \IronCart\Scan\Cron\UploadScan} job. The
                `<config_path>` mapping in `etc/crontab.xml` lets
                operators override it via Stores → Configuration →
                Ironcart → Scan → Continuous Monitoring without editing
                XML. `0 3 * * *` = daily at 03:00 store-server local time.
            -->
            <cron>
                <enabled>0</enabled>
                <schedule>0 3 * * *</schedule>
            </cron>
            <!--
                Issue #92 — Run-Scan-Now stuck-QUEUED operator notice.
                `consumer_alert_threshold_seconds` is the age (in seconds)
                an ironcart_scan_run row's started_at must exceed while
                status=queued before the admin notice (wired via
                etc/adminhtml/di.xml) fires. 60s is the default; lower it
                if you want the warning to surface faster on a sluggish
                consumer; raise it if you have a chronically slow cron
                tick. Mirrored in
                IronCart\Scan\Model\Notification\ConsumerStalledPredicate::DEFAULT_THRESHOLD_SECONDS
                so the unit test can pin the boundary without consulting
                the framework config layer.
            -->
            <runtime>
                <consumer_alert_threshold_seconds>60</consumer_alert_threshold_seconds>
            </runtime>
        </ironcart_scan>
    </default>
</config>
