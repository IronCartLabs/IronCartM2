 / Licensed under MIT.
 /
 / Registers the `ironcart:scan` console command with Magento's CommandList
 / and wires the CheckRegistry. Check entries below are ADDITIVE — sibling
 / check-pack PRs must only append new keys and must not reorder or remove
 / the existing ones to keep merges conflict-free.
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <type name="Magento\Framework\Console\CommandList">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="ironcart_scan" xsi:type="object">IronCart\Scan\Console\Command\ScanCommand</item>
            </argument>
        </arguments>
    </type>

    <type name="IronCart\Scan\Check\CheckRegistry">
        <arguments>
            <argument name="checks" xsi:type="array">
                <!-- Filesystem check pack (#6) -->
                <item name="IC-030" xsi:type="object">IronCart\Scan\Check\Filesystem\EnvPhpPermissionsCheck</item>
                <item name="IC-031" xsi:type="object">IronCart\Scan\Check\Filesystem\EnvPhpOwnershipCheck</item>
                <item name="IC-032" xsi:type="object">IronCart\Scan\Check\Filesystem\CryptKeyCheck</item>
                <item name="IC-033" xsi:type="object">IronCart\Scan\Check\Filesystem\WritableDirectoriesCheck</item>
                <item name="IC-034" xsi:type="object">IronCart\Scan\Check\Filesystem\StrayDevToolingCheck</item>
                <!-- Patch-level check pack (#3) -->
                <item name="IC-001" xsi:type="object">IronCart\Scan\Check\PatchLevel\MagentoVersionCheck</item>
                <item name="IC-002" xsi:type="object">IronCart\Scan\Check\PatchLevel\ComposerAdvisoryCheck</item>
                <!-- Operational health check pack (#7) -->
                <item name="IC-040" xsi:type="object">IronCart\Scan\Check\Operational\IndexerStateCheck</item>
                <item name="IC-041" xsi:type="object">IronCart\Scan\Check\Operational\CronLastRunCheck</item>
                <item name="IC-042" xsi:type="object">IronCart\Scan\Check\Operational\CronErrorRateCheck</item>
                <item name="IC-043" xsi:type="object">IronCart\Scan\Check\Operational\MessageQueueBacklogCheck</item>
                <!-- Runtime config check pack (#5) -->
                <item name="IC-020" xsi:type="object">IronCart\Scan\Check\Runtime\MageModeCheck</item>
                <item name="IC-021" xsi:type="object">IronCart\Scan\Check\Runtime\SecureCookieCheck</item>
                <item name="IC-022" xsi:type="object">IronCart\Scan\Check\Runtime\HttpsEnforcementCheck</item>
                <item name="IC-023" xsi:type="object">IronCart\Scan\Check\Runtime\CspModeCheck</item>
                <item name="IC-024" xsi:type="object">IronCart\Scan\Check\Runtime\ProfilerCheck</item>
                <!-- Admin posture check pack (#4) -->
                <item name="IC-010" xsi:type="object">IronCart\Scan\Check\Admin\AdminUrlFrontnameCheck</item>
                <item name="IC-011" xsi:type="object">IronCart\Scan\Check\Admin\AdminUserInventoryCheck</item>
                <item name="IC-012" xsi:type="object">IronCart\Scan\Check\Admin\TwoFactorCoverageCheck</item>
                <item name="IC-013" xsi:type="object">IronCart\Scan\Check\Admin\WeakPasswordIndicatorCheck</item>
                <!-- Webhook posture check pack (#49) -->
                <item name="IC-090" xsi:type="object">IronCart\Scan\Check\Webhooks\PlaintextDestinationCheck</item>
                <item name="IC-091" xsi:type="object">IronCart\Scan\Check\Webhooks\SignatureSecretCheck</item>
                <item name="IC-092" xsi:type="object">IronCart\Scan\Check\Webhooks\RetryPolicyCheck</item>
                <item name="IC-093" xsi:type="object">IronCart\Scan\Check\Webhooks\PrivateNetworkDestinationCheck</item>
                <!-- Code-smell check pack (v2, #45) — strict pattern scan over app/code/** -->
                <item name="IC-050" xsi:type="object">IronCart\Scan\Check\CodeSmell\EvalCheck</item>
                <item name="IC-051" xsi:type="object">IronCart\Scan\Check\CodeSmell\UnserializeUntrustedCheck</item>
                <item name="IC-052" xsi:type="object">IronCart\Scan\Check\CodeSmell\DynamicIncludeCheck</item>
                <item name="IC-053" xsi:type="object">IronCart\Scan\Check\CodeSmell\ShellExecCheck</item>
                <item name="IC-054" xsi:type="object">IronCart\Scan\Check\CodeSmell\PregReplaceEvalModifierCheck</item>
                <!-- File-integrity check pack (#47, #50). IC-071 / IC-073 are
                     emitted by the same class as IC-070 / IC-072 respectively
                     when no manifest is available, so they are NOT registered
                     separately here. -->
                <item name="IC-070" xsi:type="object">IronCart\Scan\Check\FileIntegrity\CoreFileIntegrityCheck</item>
                <item name="IC-072" xsi:type="object">IronCart\Scan\Check\FileIntegrity\ComposerLockIntegrityCheck</item>
                <!-- CSP posture check pack (#48). Issues ONE local-loopback HEAD
                     probe via CspProbeRunner (shared instance, declared below).
                     The probe is gated by LoopbackHostGuard and skipped entirely
                     when the storefront base URL is unconfigured (example.com),
                     which IC-085 reports as a LOW finding. -->
                <item name="IC-080" xsi:type="object">IronCart\Scan\Check\Runtime\Csp\CspMissingCheck</item>
                <item name="IC-081" xsi:type="object">IronCart\Scan\Check\Runtime\Csp\CspReportEndpointCheck</item>
                <item name="IC-082" xsi:type="object">IronCart\Scan\Check\Runtime\Csp\CspScriptSrcUnsafeCheck</item>
                <item name="IC-083" xsi:type="object">IronCart\Scan\Check\Runtime\Csp\CspFrameAncestorsCheck</item>
                <item name="IC-084" xsi:type="object">IronCart\Scan\Check\Runtime\Csp\CspReportOnlyInProductionCheck</item>
                <item name="IC-085" xsi:type="object">IronCart\Scan\Check\Runtime\Csp\CspBaseUrlConfiguredCheck</item>
                <!-- CVE cross-reference check pack (v2, #46). POSTs composer
                     package list to https://ironcart.dev/api/cve (the proxied
                     branch of the OSV.dev decision). Opt-in by default OFF —
                     the check emits one info-level finding pointing the
                     operator at the admin config until ironcart_scan/cve/enabled
                     is flipped. IC-061 is emitted by the same class on transport
                     failure so it is NOT registered separately here. -->
                <item name="IC-060" xsi:type="object">IronCart\Scan\Check\Cve\ComposerCveCheck</item>
            </argument>
        </arguments>
    </type>

    <!--
        CVE proxy client — production wires the hardened ext-curl
        implementation. Unit tests inject a fake; integration tests can
        override this preference to a local stub for the docker-compose
        sandbox without touching the check class itself.
    -->
    <preference for="IronCart\Scan\Check\Cve\CveProxyClient"
                type="IronCart\Scan\Check\Cve\CurlCveProxyClient"/>

    <!--
        CSP probe runner — shared so all six IC-08x checks consult the same
        single HEAD probe. The CspProbeClient preference wires the cURL
        implementation; integration tests inside the docker-compose Magento
        sandbox can override this preference to a local fake without
        touching the check classes themselves.
    -->
    <preference for="IronCart\Scan\Check\Runtime\Csp\CspProbeClient"
                type="IronCart\Scan\Check\Runtime\Csp\CurlCspProbeClient"/>
    <type name="IronCart\Scan\Check\Runtime\Csp\CspProbeRunner" shared="true"/>

    <!--
        v3 — opt-in hosted scan reporting (#57).

        Module-side companion to the IronCartWeb /api/scan/ingest endpoint.
        Default OFF; gated by `ironcart_scan/upload/enabled`. The CurlUploadClient
        is host-pinned to `ironcart.dev` and rejects any URL whose host does
        not match before any socket is opened.

        Integration tests inside the docker-compose Magento sandbox can swap
        the UploadClient preference to a fake without touching the runner /
        ScanCommand wiring.
    -->
    <preference for="IronCart\Scan\Check\Upload\UploadClient"
                type="IronCart\Scan\Check\Upload\CurlUploadClient"/>
    <type name="IronCart\Scan\Check\Upload\UploadPayloadBuilder">
        <arguments>
            <argument name="moduleVersion" xsi:type="string">1.2.0</argument>
            <argument name="licenseConfig" xsi:type="object">IronCart\Scan\Check\License\LicenseConfig</argument>
        </arguments>
    </type>
    <type name="IronCart\Scan\Check\Upload\UploadRunner">
        <arguments>
            <argument name="moduleVersion" xsi:type="string">1.2.0</argument>
        </arguments>
    </type>

    <!--
        v5 — Pro-tier license verifier (#103).

        Module-side half of the Pro entitlement flow. Operator pastes an
        Ed25519-signed license blob into `ironcart_scan/license/blob`;
        UploadPayloadBuilder forwards it inside the `--upload` payload
        when (and only when) it verifies cleanly against the compiled-in
        public key. The verifier is stateless and is wired shared so a
        single `bin/magento ironcart:scan` invocation parses the blob
        once.

        Module behaviour does NOT change with license state — all 43
        checks still run identically. Only the upload envelope picks up
        an extra `license_blob` field so the hosted backend can flag the
        resulting scan run as `tier='pro'`.
    -->
    <type name="IronCart\Scan\Check\License\LicenseVerifier" shared="true"/>
    <type name="IronCart\Scan\Check\License\LicenseConfig" shared="true"/>

    <!--
        v4 — continuous-monitoring cron (#64).

        The cron handler drives the same scan + upload pipeline as
        `bin/magento ironcart:scan` with the `upload` flag. Logging is routed through a
        virtual `IronCartScanCronLogger` channel that writes to
        `var/log/ironcart_scan.log` (separate from Magento's main
        `var/log/cron.log` so operators can tail the upload outcome in
        isolation), with the regular Magento logger as fallback so
        critical errors still appear in the system-wide log too.

        Default state is OFF — the job exits at the
        `ironcart_scan/cron/enabled` gate before loading the check
        registry, so a fresh `composer require` of this module never
        silently starts outbound HTTP traffic.
    -->
    <virtualType name="IronCartScanCronLogHandler"
                 type="Magento\Framework\Logger\Handler\Base">
        <arguments>
            <argument name="fileName" xsi:type="string">/var/log/ironcart_scan.log</argument>
        </arguments>
    </virtualType>
    <virtualType name="IronCartScanCronLogger"
                 type="Magento\Framework\Logger\Monolog">
        <arguments>
            <argument name="name" xsi:type="string">ironcart_scan_cron</argument>
            <argument name="handlers" xsi:type="array">
                <item name="system" xsi:type="object">IronCartScanCronLogHandler</item>
            </argument>
        </arguments>
    </virtualType>
    <type name="IronCart\Scan\Cron\UploadScan">
        <arguments>
            <argument name="logger" xsi:type="object">IronCartScanCronLogger</argument>
        </arguments>
    </type>
</config>
