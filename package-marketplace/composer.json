{
    "name": "ironcartlabs/magento-scan-marketplace",
    "description": "Ironcart Scan — read-only Magento 2 security posture scanner. Adobe Commerce Marketplace edition (mirrors the OSS ironcartlabs/magento-scan package one-for-one; differs only in listing metadata).",
    "type": "magento2-module",
    "license": "MIT",
    "homepage": "https://ironcart.dev",
    "keywords": [
        "magento",
        "magento2",
        "security",
        "scanner",
        "posture",
        "audit",
        "compliance",
        "ironcart"
    ],
    "authors": [
        {
            "name": "Ironcart",
            "email": "support@ironcart.dev",
            "homepage": "https://ironcart.dev",
            "role": "Maintainer"
        }
    ],
    "support": {
        "email": "support@ironcart.dev",
        "issues": "https://github.com/IronCartLabs/IronCartM2/issues",
        "source": "https://github.com/IronCartLabs/IronCartM2",
        "security": "https://github.com/IronCartLabs/IronCartM2/security/policy",
        "docs": "https://ironcart.dev/docs"
    },
    "require": {
        "php": "~8.1.0||~8.2.0||~8.3.0",
        "magento/framework": "^103.0"
    },
    "require-dev": {
        "symfony/console": "^6.4 || ^7.0"
    },
    "autoload": {
        "files": ["registration.php"],
        "psr-4": {
            "IronCart\\Scan\\": ""
        }
    },
    "extra": {
        "module-version": "1.2.0",
        "map": [
            ["*", "IronCart/Scan"]
        ]
    },
    "archive": {
        "exclude": [
            "/.github",
            "/.sandbox",
            "/_m2-workspace",
            "/tests",
            "/Test",
            "/docs",
            "/bin/build-manifest.php",
            "/bin/build-composer-manifest.php",
            "/bin/build-marketplace.php",
            "/CHANGELOG.md",
            "/CODEOWNERS",
            "/CONTRIBUTING.md",
            "/Makefile",
            "/package-marketplace",
            "/.gitignore",
            "/.gitattributes"
        ]
    }
}
